<%- include('../partials/admin-head', { title: '仪表盘' }) %>

<%- include('../partials/admin-nav', { active: 'dashboard' }) %>

<main>
  <div class="admin-main">
    <div class="admin-page-header">
      <h1 class="admin-page-title">仪表盘</h1>
      <span style="color:var(--text-muted);font-size:0.9rem;">欢迎回来，<%= username %></span>
    </div>

    <div class="stat-grid">
      <div class="stat-card">
        <div class="stat-card-label">省份总数</div>
        <div class="stat-card-value count-animate"><%= stats.provinceCount %></div>
      </div>
      <div class="stat-card">
        <div class="stat-card-label">照片总数</div>
        <div class="stat-card-value count-animate"><%= stats.photoCount %></div>
      </div>
      <div class="stat-card">
        <div class="stat-card-label">今日访问</div>
        <div class="stat-card-value count-animate"><%= stats.todayVisits || 0 %></div>
      </div>
      <div class="stat-card">
        <div class="stat-card-label">总访问量</div>
        <div class="stat-card-value count-animate"><%= stats.totalVisits || 0 %></div>
      </div>
      <div class="stat-card">
        <div class="stat-card-label">草稿</div>
        <div class="stat-card-value count-animate"><%= stats.draftCount || 0 %></div>
      </div>
      <div class="stat-card" style="<%= stats.pendingComments > 0 ? 'border-color:var(--accent);' : '' %>">
        <div class="stat-card-label">待审核评论</div>
        <div class="stat-card-value count-animate" style="<%= stats.pendingComments > 0 ? 'color:var(--accent);' : '' %>">
          <%= stats.pendingComments || 0 %>
          <% if (stats.pendingComments > 0) { %>
            <a href="/admin/comments" style="font-size:0.75rem;display:block;color:var(--accent);text-decoration:none;font-weight:400;">前往审核</a>
          <% } %>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-card-label">最近更新</div>
        <div class="stat-card-sub">
          <% if (stats.recentProvince) { %>
            <%= stats.recentProvince.display %>
            <small><%= stats.recentProvince.updated_at %></small>
          <% } else { %>
            <span style="color:var(--text-muted);">暂无数据</span>
          <% } %>
        </div>
      </div>
    </div>

    <div class="action-bar">
      <a href="/admin/provinces/new" class="btn btn-primary">
        <svg class="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        新增省份
      </a>
      <a href="/admin/photos" class="btn">
        <svg class="icon-sm icon-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        管理照片
      </a>
      <a href="/admin/provinces" class="btn">
        <svg class="icon-sm icon-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        省份列表
      </a>
      <button class="btn" onclick="exportData()">
        <svg class="icon-sm icon-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        导出 JSON
      </a>
      <button class="btn" onclick="importData()">
        <svg class="icon-sm icon-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        导入 JSON
      </button>
      <a href="/api/admin/backup" class="btn">
        <svg class="icon-sm icon-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
        下载备份
      </a>
    </div>

    <div class="admin-table-wrap">
      <div class="admin-table-head">所有省份</div>
      <div style="overflow-x:auto;">
        <table class="admin-table">
          <thead>
            <tr>
              <th>省份</th>
              <th>旅行时间</th>
              <th class="text-center">照片数</th>
              <th class="text-center">状态</th>
              <th class="text-right">操作</th>
            </tr>
          </thead>
          <tbody>
            <% if (provinces.length === 0) { %>
              <tr>
                <td colspan="5">
                  <div class="empty-state" style="padding:40px;">
                    <div class="empty-state-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    </div>
                    <div class="empty-state-text">暂无省份数据</div>
                  </div>
                </td>
              </tr>
            <% } else { %>
              <% provinces.forEach(function(p) { %>
                <tr data-province-id="<%= p.id %>">
                  <td>
                    <div class="cell-name"><%= p.display %></div>
                    <div class="cell-sub"><%= p.province %></div>
                  </td>
                  <td class="cell-muted"><%= p.period || '-' %></td>
                  <td class="cell-center"><%= p.photo_count %></td>
                  <td class="cell-center">
                    <% if (p.status === 'draft') { %>
                      <span style="color:var(--accent);font-size:0.82rem;">草稿</span>
                    <% } else { %>
                      <span style="color:#4CAF50;font-size:0.82rem;">已发布</span>
                    <% } %>
                  </td>
                  <td class="cell-actions">
                    <a href="/admin/provinces/<%= p.id %>/edit" class="btn">编辑</a>
                    <button class="btn" onclick="toggleStatus(<%= p.id %>, <%- JSON.stringify(p.display) %>)">切换状态</button>
                    <button class="btn btn-danger" onclick="deleteProvince(<%= p.id %>, <%- JSON.stringify(p.display) %>)">删除</button>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</main>

<script>
function deleteProvince(id, name) {
  if (!confirm('确定要删除"' + name + '"吗？所有相关照片也会被删除。')) return;
  fetch('/api/admin/provinces/' + id, { method: 'DELETE' })
    .then(r => r.json())
    .then(data => {
      if (data.error) return showToast('删除失败: ' + data.error);
      showToast('已删除 ' + name);
      setTimeout(() => location.reload(), 800);
    })
    .catch(() => showToast('删除失败'));
}

function toggleStatus(id, name) {
  fetch('/api/admin/provinces/' + id + '/toggle-status', { method: 'PUT' })
    .then(r => r.json())
    .then(data => {
      if (data.error) return showToast('操作失败: ' + data.error);
      showToast(name + ' 已切换为 ' + (data.status === 'published' ? '已发布' : '草稿'));
      setTimeout(() => location.reload(), 800);
    })
    .catch(() => showToast('操作失败'));
}
</script>

<%- include('../partials/footer') %>

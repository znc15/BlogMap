<%- include('../partials/admin-head', { title: '修改密码' }) %>

<%- include('../partials/admin-nav', { active: 'password' }) %>

<main>
  <div class="admin-main" style="max-width:480px;">
    <div class="admin-page-header">
      <h1 class="admin-page-title">修改管理员密码</h1>
    </div>

    <% if (typeof success !== 'undefined' && success) { %>
      <div style="background:rgba(76,175,80,0.12);border:1px solid #4CAF50;border-radius:10px;padding:14px 18px;margin-bottom:20px;color:#4CAF50;font-size:0.9rem;display:flex;align-items:center;gap:8px;">
        <svg class="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <%= success %>
      </div>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
      <div style="background:rgba(214,90,49,0.12);border:1px solid var(--accent);border-radius:10px;padding:14px 18px;margin-bottom:20px;color:var(--accent);font-size:0.9rem;display:flex;align-items:center;gap:8px;">
        <svg class="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <%= error %>
      </div>
    <% } %>

    <form method="post" action="/admin/change-password" class="form-stack">
      <div class="field">
        <label class="field-label">原密码</label>
        <input class="field-input" type="password" name="oldPassword" placeholder="输入当前密码" required autofocus>
      </div>
      <div class="field">
        <label class="field-label">新密码</label>
        <input class="field-input" type="password" name="newPassword" placeholder="至少 6 位" required minlength="6">
      </div>
      <div class="field">
        <label class="field-label">确认新密码</label>
        <input class="field-input" type="password" name="confirmPassword" placeholder="再次输入新密码" required minlength="6">
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary" style="padding:12px 28px;font-size:1rem;">修改密码</button>
        <a href="/admin/dashboard" class="btn" style="padding:12px 28px;font-size:1rem;text-decoration:none;">取消</a>
      </div>
    </form>
  </div>
</main>

<%- include('../partials/footer') %>
